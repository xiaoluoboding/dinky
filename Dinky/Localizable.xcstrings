    "Removes embedded EXIF, GPS, camera info, PDF properties (title, subject, keywords), and color profiles when supported. Does not remove Finder’s Get Info → Comments; use Preserve Finder comments in Settings → Compression for that." : {
      "comment" : "Settings UI: Strip metadata explanation."
    },
    "Removes embedded EXIF, location, camera info, and PDF properties when supported. Finder Get Info comments are separate — turn on Preserve Finder comments below." : {
      "comment" : "Sidebar: strip metadata helper."
    },
    "Removes EXIF, GPS, camera info, and color profiles. Reduces file size slightly." : {
      "comment" : "Settings UI.",
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Entfernt EXIF, GPS, Kamerainformationen und Farbprofile. Reduziert die Dateigröße geringfügig."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elimina EXIF, GPS, información de la cámara y perfiles de color. Reduce ligeramente el tamaño del archivo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Supprime EXIF, GPS, informations sur l'appareil photo et profils de couleurs. Réduit légèrement la taille du fichier."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rimuove EXIF, GPS, informazioni sulla fotocamera e profili colore. Riduce leggermente la dimensione del file."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "EXIF、GPS、カメラ情報、カラープロファイルを削除します。ファイルサイズをわずかに削減します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "EXIF, GPS, 카메라 정보, 색상 프로필을 제거합니다. 파일 크기가 약간 줄어듭니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verwijdert EXIF, GPS, camera-informatie en kleurprofielen. Verkleint de bestandsgrootte enigszins."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Remove EXIF, GPS, informações da câmera e perfis de cores. Reduz ligeiramente o tamanho do arquivo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Удаляет EXIF, GPS, информацию о камере и цветовые профили. Немного уменьшает размер файла."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "EXIF, GPS, kamera bilgileri ve renk profillerini kaldırır. Dosya boyutunu biraz küçültür."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "删除 EXIF、GPS、相机信息和颜色配置文件。稍微减小文件大小。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "刪除 EXIF、GPS、相機資訊和顏色設定檔。稍微減小文件大小。"
          }
        }
      }
    },
    "Removes finished rows shortly after a batch completes. Failed or skipped files stay so you can act on them." : {
      "comment" : "Settings UI.",
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Entfernt fertige Zeilen kurz nach Abschluss eines Stapels. Fehlgeschlagene oder übersprungene Dateien bleiben erhalten, sodass Sie darauf reagieren können."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elimina filas terminadas poco después de que se completa un lote. Los archivos fallidos u omitidos permanecen para que puedas actuar en consecuencia."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Supprime les lignes terminées peu de temps après la fin d'un lot. Les fichiers ayant échoué ou ignorés restent afin que vous puissiez agir dessus."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rimuove le righe finite subito dopo il completamento di un batch. I file non riusciti o saltati rimangono in modo che tu possa agire su di essi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "バッチが完了した直後に、終了した行を削除します。失敗したファイルまたはスキップされたファイルはそのまま残るので、それらに対して対処できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "일괄 처리가 완료된 직후 완료된 행을 제거합니다. 실패했거나 건너뛴 파일은 그대로 유지되어 조치를 취할 수 있습니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verwijdert voltooide rijen kort nadat een batch is voltooid. Mislukte of overgeslagen bestanden blijven staan, zodat u er actie op kunt ondernemen."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Remove linhas concluídas logo após a conclusão de um lote. Os arquivos com falha ou ignorados permanecem para que você possa tomar medidas sobre eles."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Удаляет готовые строки вскоре после завершения пакета. Неудачные или пропущенные файлы остаются, и вы можете действовать с ними."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bir toplu iş tamamlandıktan kısa bir süre sonra tamamlanan satırları kaldırır. Başarısız olan veya atlanan dosyalar kalır, böylece onlar üzerinde işlem yapabilirsiniz."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "批次完成后不久删除已完成的行。失败或跳过的文件会保留下来，以便您可以对其进行操作。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "批次完成後不久刪除已完成的行。失敗或跳過的文件會保留下來，以便您可以對其進行操作。"
          }
        }
      }
    },
