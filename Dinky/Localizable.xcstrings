        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Efface le total cumulé affiché dans l’historique. L’historique de la session est inchangé – effacez-le dans la fenêtre Historique."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cancella il totale parziale mostrato nella Cronologia. La cronologia delle sessioni è rimasta invariata: cancellala dalla finestra Cronologia."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "履歴に表示されている累計をクリアします。セッション履歴は変更されません。履歴ウィンドウからセッション履歴をクリアしてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "기록에 표시된 누계를 지웁니다. 세션 기록은 변경되지 않습니다. 기록 창에서 삭제하세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wist het lopende totaal dat in de geschiedenis wordt weergegeven. De sessiegeschiedenis is ongewijzigd – duidelijk dat vanuit het venster Geschiedenis."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Limpa o total acumulado mostrado no Histórico. O histórico da sessão permanece inalterado – limpe-o na janela Histórico."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Очищает общий счётчик, показанный в окне «История». Список сеансов не меняется — очистите его в самом окне «История»."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Geçmiş'te gösterilen cari toplamı temizler. Oturum geçmişi değişmedi; bunu Geçmiş penceresinden temizleyin."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "清除历史记录中显示的运行总计。会话历史记录未更改 - 从“历史记录”窗口中清除该历史记录。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "清除歷史記錄中顯示的運行總計。會話歷史記錄未變更 - 從「歷史記錄」視窗中清除該記錄。"
          }
        }
      }
    },
