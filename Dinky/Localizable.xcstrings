    "Off keeps source resolution and just re-encodes for size." : {
      "comment" : "Settings UI.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bei „Aus“ bleibt die Quellauflösung erhalten und die Größe wird lediglich neu codiert."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desactivado mantiene la resolución de origen y simplemente vuelve a codificar el tamaño."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Off conserve la résolution de la source et réencode simplement la taille."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Disattivato mantiene la risoluzione sorgente e ricodifica solo per le dimensioni."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
