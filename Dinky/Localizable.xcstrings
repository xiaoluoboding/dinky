    "Applies to images, videos, and PDFs. Skip files where savings fall below this threshold." : {
      "comment" : "Settings UI.",
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gilt für Bilder, Videos und PDFs. Überspringen Sie Dateien, bei denen die Einsparungen unter diesen Schwellenwert fallen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se aplica a imágenes, videos y archivos PDF. Omita archivos cuyos ahorros caigan por debajo de este umbral."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "S'applique aux images, vidéos et fichiers PDF. Ignorez les fichiers où les économies sont inférieures à ce seuil."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si applica a immagini, video e PDF. Salta i file in cui il risparmio scende al di sotto di questa soglia."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "画像、ビデオ、PDF に適用されます。節約量がこのしきい値を下回るファイルをスキップします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이미지, 비디오, PDF에 적용됩니다. 절감액이 이 기준점 미만인 파일은 건너뛰세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Geldt voor afbeeldingen, video's en pdf's. Sla bestanden over waar de besparingen onder deze drempel vallen."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aplica-se a imagens, vídeos e PDFs. Ignore os arquivos onde a economia estiver abaixo desse limite."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Применяется к изображениям, видео и PDF-файлам. Пропускать файлы, в которых экономия падает ниже этого порога."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resimler, videolar ve PDF'ler için geçerlidir. Tasarrufların bu eşiğin altına düştüğü dosyaları atlayın."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "适用于图像、视频和 PDF。跳过节省低于此阈值的文件。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "適用於圖像、影片和 PDF。跳過節省低於此閾值的檔案。"
          }
        }
      }
    },
