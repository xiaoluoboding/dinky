        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "낮음 / 중간 / 높음은 미디어에서 편평화(가장 작음)를 선택한 경우 적용됩니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Laag / Medium / Hoog zijn van toepassing wanneer Flatten (kleinste) is geselecteerd onder Media."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Baixo/Médio/Alto se aplica quando Nivelar (menor) é selecionado em Mídia."
