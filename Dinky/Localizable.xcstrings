    "The update didn’t contain Dinky.app." : {
      "comment" : "In-app updater error."
    },
    "The video files to compress." : {
      "comment" : "Shortcuts: videos parameter description."
    },
    "These are the defaults for the main window. Presets can set their own folder and filename rules." : {
      "comment" : "Settings UI.",
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dies sind die Standardeinstellungen für das Hauptfenster. Voreinstellungen können ihre eigenen Ordner- und Dateinamenregeln festlegen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estos son los valores predeterminados para la ventana principal. Los ajustes preestablecidos pueden establecer sus propias reglas de carpetas y nombres de archivos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ce sont les valeurs par défaut de la fenêtre principale. Les préréglages peuvent définir leurs propres règles de dossier et de nom de fichier."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Queste sono le impostazioni predefinite per la finestra principale. Le preimpostazioni possono impostare le proprie regole per cartelle e nomi di file."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "これらはメイン ウィンドウのデフォルトです。プリセットでは、独自のフォルダーとファイル名のルールを設定できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이는 기본 창의 기본값입니다. 사전 설정은 자체 폴더 및 파일 이름 규칙을 설정할 수 있습니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dit zijn de standaardinstellingen voor het hoofdvenster. Voorinstellingen kunnen hun eigen map- en bestandsnaamregels instellen."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estes são os padrões da janela principal. As predefinições podem definir suas próprias regras de pasta e nome de arquivo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Это значения по умолчанию для главного окна. Пресеты могут устанавливать свои собственные правила для папок и имен файлов."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bunlar ana pencerenin varsayılan ayarlarıdır. Ön ayarlar kendi klasör ve dosya adı kurallarını ayarlayabilir."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这些是主窗口的默认值。预设可以设置自己的文件夹和文件名规则。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
