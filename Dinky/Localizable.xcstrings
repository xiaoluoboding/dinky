    "Double-click to open in the default app. Drag the row to move the file." : {
      "comment" : "VoiceOver hint for result row.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Doppelklicken Sie, um die Standard-App zu öffnen. Ziehen Sie die Zeile, um die Datei zu verschieben."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Haga doble clic para abrir en la aplicación predeterminada. Arrastra la fila para mover el archivo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
