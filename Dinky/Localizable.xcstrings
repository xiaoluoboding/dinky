          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Настраивает сжатие каждого файла: кодировку изображения в зависимости от содержимого, мощность видео в зависимости от разрешения и битрейта, уровень PDF в документе."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
