    "For watch folders, presets, and full troubleshooting, open Dinky Help from the Help menu (%@)." : {
      "comment" : "Settings Shortcuts tab footer; argument is help shortcut.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Für Überwachungsordner, Voreinstellungen und vollständige Fehlerbehebung öffnen Sie die Dinky-Hilfe über das Hilfemenü (%@)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para ver carpetas, ajustes preestablecidos y solución de problemas completa, abra Dinky Help desde el menú Ayuda (%@)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pour les dossiers de surveillance, les préréglages et le dépannage complet, ouvrez l'aide Dinky à partir du menu Aide (%@)."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Per controllare le cartelle, le preimpostazioni e la risoluzione completa dei problemi, apri la Guida Dinky dal menu Aiuto (%@)."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "監視フォルダー、プリセット、および完全なトラブルシューティングについては、[ヘルプ] メニュー (%@) から Dinky ヘルプを開きます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "감시 폴더, 사전 설정 및 전체 문제 해결을 보려면 도움말 메뉴(%@)에서 Dinky 도움말을 여세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Voor controlemappen, voorinstellingen en volledige probleemoplossing opent u Dinky Help vanuit het Help-menu (%@)."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para pastas monitoradas, predefinições e solução de problemas completa, abra Dinky Help no menu Ajuda (%@)."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Для просмотра папок просмотра, настроек и полного устранения неполадок откройте Справку Dinky из меню «Справка» (%@)."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "İzleme klasörleri, ön ayarlar ve tam sorun giderme için Yardım menüsünden (%@) Dinky Yardım'ı açın."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "对于监视文件夹、预设和完整的故障排除，请从“帮助”菜单 (%@) 打开 Dinky 帮助。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "對於監視資料夾、預設和完整的故障排除，請從「幫助」功能表 (%@) 打開 Dinky 幫助。"
          }
        }
      }
    },
