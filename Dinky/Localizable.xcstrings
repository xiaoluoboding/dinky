    "Low / Medium / High and grayscale apply when Flatten (smallest) is selected." : {
      "comment" : "Settings UI.",
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niedrig / Mittel / Hoch und Graustufen gelten, wenn „Abflachen (am kleinsten)“ ausgewählt ist."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bajo / Medio / Alto y escala de grises se aplican cuando se selecciona Aplanar (más pequeño)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Faible / Moyen / Élevé et les niveaux de gris s'appliquent lorsque Aplatir (le plus petit) est sélectionné."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Basso / Medio / Alto e scala di grigi si applicano quando è selezionato Appiattisci (il più piccolo)."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "[低]/[中]/[高]およびグレースケールは、[フラット化] (最小) が選択されている場合に適用されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "낮음/중간/높음 및 회색조는 Flatten(최소)을 선택한 경우 적용됩니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Laag / Gemiddeld / Hoog en grijstinten zijn van toepassing wanneer Afvlakken (kleinste) is geselecteerd."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Baixo/Médio/Alto e tons de cinza se aplicam quando Nivelar (menor) é selecionado."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Низкий/Средний/Высокий и оттенки серого применяются, когда выбран параметр «Сгладить» (наименьший)."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Düzleştir (en küçük) seçildiğinde Düşük / Orta / Yüksek ve gri tonlama uygulanır."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "当选择“展平”（最小）时，将应用“低”/“中”/“高”和灰度。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "當選擇“展平”（最小）時，將應用“低”/“中”/“高”和灰度。"
          }
        }
      }
    },
    "Low / Medium / High apply when Flatten (smallest) is selected under Media." : {
      "comment" : "Settings UI.",
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niedrig / Mittel / Hoch gelten, wenn „Abflachen (am kleinsten)“ unter „Medien“ ausgewählt ist."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bajo / Medio / Alto se aplica cuando se selecciona Aplanar (el más pequeño) en Medios."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Faible / Moyen / Élevé s'applique lorsque Aplatir (le plus petit) est sélectionné sous Média."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Basso / Medio / Alto si applicano quando Appiattisci (il più piccolo) è selezionato in Media."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "[低]/[中]/[高]は、[メディア]で[フラット化(最小)]が選択されている場合に適用されます。"
